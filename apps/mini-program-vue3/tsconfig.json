{
  "compilerOptions": {
    "target": "esnext",
    "jsx": "preserve",
    "lib": ["DOM", "ESNext"],
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["src/*"]
    },
    "resolveJsonModule": true,
    "types": ["@dcloudio/types", "node"],
    "allowJs": true,
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "src/main.ts",
    "src/App.vue",
    "src/pages/home/**/*.vue",
    "src/pages/category/**/*.vue",
    "src/pages/store/**/*.vue",
    "src/pages/product/**/*.vue",
    "src/pages/booking/**/*.vue",
    "src/pages/mine/**/*.vue",
    "src/services/**/*.ts",
    "src/stores/**/*.ts",
    "src/types/**/*.ts",
    "src/utils/format.ts",
    "types/env.d.ts",
    "types/module.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "uni_modules",
    "src/api",
    "src/components",
    "src/hooks",
    "src/locales",
    "src/pages/common",
    "src/pages/tab",
    "src/plugins",
    "src/router",
    "src/store",
    "src/utils/request"
  ]
}
