generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ========== 门店 ==========
model Store {
  id            String    @id @default(uuid())
  name          String    @db.VarChar(100)
  address       String    @db.VarChar(255)
  phone         String    @db.VarChar(20)
  businessHours String?   @map("business_hours") @db.VarChar(100)
  status        Int       @default(1) // 1:active, 0:inactive
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  productConfigs StoreProductConfig?
  reservations   Reservation[]
  storeProducts  StoreProduct[]
  storePackages  StorePackage[]

  @@map("stores")
}

// ========== 车型 ==========
model CarModel {
  id        String   @id @default(uuid())
  brand     String   @db.VarChar(50)
  model     String   @db.VarChar(50)
  year      String?  @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  productRelations ProductCarModelRelation[]
  packageRelations PackageCarModelRelation[]

  @@map("car_models")
}

// ========== 商品 ==========
model Product {
  id               String    @id @default(uuid())
  name             String    @db.VarChar(100)
  mainImages       String? // JSON array of image URLs
  priceDescription String?   @map("price_description") @db.VarChar(100)
  brief            String?   @db.VarChar(200)
  description      String?   @db.Text
  specifications   String?   @db.Text
  category         String?   @db.VarChar(20) // interior/exterior/function/comfort
  status           Int       @default(1)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  carModelRelations ProductCarModelRelation[]
  packageItems      PackageProduct[]
  storeProducts     StoreProduct[]

  @@map("products")
}

// 商品-车型适配关系
model ProductCarModelRelation {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  carModelId String   @map("car_model_id")
  product    Product  @relation(fields: [productId], references: [id])
  carModel   CarModel @relation(fields: [carModelId], references: [id])

  @@unique([productId, carModelId])
  @@map("product_car_model_relations")
}

// ========== 套餐 ==========
model Package {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(100)
  mainImages  String?
  price       Decimal?  @db.Decimal(10, 2)
  description String?   @db.Text
  status      Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  carModelRelations PackageCarModelRelation[]
  packageProducts   PackageProduct[]
  storePackages     StorePackage[]

  @@map("packages")
}

// 套餐-商品关系
model PackageProduct {
  id        String  @id @default(uuid())
  packageId String  @map("package_id")
  productId String  @map("product_id")
  package   Package @relation(fields: [packageId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@unique([packageId, productId])
  @@map("package_product_relations")
}

// 套餐-车型适配关系
model PackageCarModelRelation {
  id         String   @id @default(uuid())
  packageId  String   @map("package_id")
  carModelId String   @map("car_model_id")
  package    Package  @relation(fields: [packageId], references: [id])
  carModel   CarModel @relation(fields: [carModelId], references: [id])

  @@unique([packageId, carModelId])
  @@map("package_car_model_relations")
}

// ========== 门店商品配置 ==========
model StoreProductConfig {
  id        String   @id @default(uuid())
  storeId   String   @unique @map("store_id")
  store     Store    @relation(fields: [storeId], references: [id])
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("store_product_configs")
}

// 门店-商品关系（多对多）
model StoreProduct {
  id        String  @id @default(uuid())
  storeId   String  @map("store_id")
  productId String  @map("product_id")
  store     Store   @relation(fields: [storeId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@unique([storeId, productId])
  @@map("store_products")
}

// 门店-套餐关系（多对多）
model StorePackage {
  id        String  @id @default(uuid())
  storeId   String  @map("store_id")
  packageId String  @map("package_id")
  store     Store   @relation(fields: [storeId], references: [id])
  package   Package @relation(fields: [packageId], references: [id])

  @@unique([storeId, packageId])
  @@map("store_packages")
}

// ========== 用户 ==========
model User {
  id            String   @id @default(uuid())
  wechatOpenid  String?  @unique @map("wechat_openid") @db.VarChar(100)
  wechatUnionid String?  @map("wechat_unionid") @db.VarChar(100)
  phone         String?  @db.VarChar(20)
  nickname      String?  @db.VarChar(50)
  avatarUrl     String?  @map("avatar_url") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  reservations Reservation[]

  @@map("users")
}

// ========== 管理员 ==========
model AdminUser {
  id        String   @id @default(uuid())
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255)
  nickname  String?  @db.VarChar(50)
  role      String   @default("admin") @db.VarChar(20) // admin/super_admin
  status    Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

// ========== 预约单 ==========
model Reservation {
  id              String   @id @default(uuid())
  orderNo         String   @unique @map("order_no") @db.VarChar(20)
  userId          String   @map("user_id")
  storeId         String   @map("store_id")
  productId       String?  @map("product_id")
  packageId       String?  @map("package_id")
  userPhone       String   @map("user_phone") @db.VarChar(20)
  carModel        String   @map("car_model") @db.VarChar(100)
  appointmentDate DateTime @map("appointment_date") @db.Date
  timeSlot        String?  @map("time_slot") @db.VarChar(20) // morning/afternoon/evening
  remark          String?  @db.Text
  status          String   @default("pending") @db.VarChar(20) // pending/contacted/confirmed/completed/closed
  handleRemark    String?  @map("handle_remark") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user       User                   @relation(fields: [userId], references: [id])
  store      Store                  @relation(fields: [storeId], references: [id])
  statusLogs ReservationStatusLog[]

  @@map("reservations")
}

// 预约单状态变更记录
model ReservationStatusLog {
  id            String   @id @default(uuid())
  reservationId String   @map("reservation_id")
  oldStatus     String?  @map("old_status") @db.VarChar(20)
  newStatus     String   @map("new_status") @db.VarChar(20)
  operatorId    String?  @map("operator_id")
  remark        String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  reservation Reservation @relation(fields: [reservationId], references: [id])

  @@map("reservation_status_logs")
}

// ========== 首页配置 ==========
model HomePageConfig {
  id          String   @id @default(uuid())
  configKey   String   @unique @map("config_key") @db.VarChar(50)
  configValue String   @map("config_value") @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("home_page_configs")
}
